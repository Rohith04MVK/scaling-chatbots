# Copy to .env and fill in values.
# Docker Compose reads this file for ${VAR} substitution.

# --- Local (docker compose up) ---
CHATLOG_GROQ_API_KEY=
CHATLOG_CORS_ORIGINS=http://localhost:3000
# Optional local overrides (Compose sets these for api/consumer):
# CHATLOG_REDIS_URL=redis://localhost:6379/0
# CHATLOG_DATABASE_URL=postgresql+asyncpg://chatlog:chatlog@localhost:5432/chatlog

# --- AWS / production (docker compose -f docker-compose.prod.yml up) ---
# Public URL browsers use to reach Caddy on port 80. No trailing slash.
# Examples:
#   PUBLIC_HOST=http://3.14.15.16
#   PUBLIC_HOST=http://ec2-3-14-15-16.compute-1.amazonaws.com
#   PUBLIC_HOST=https://logs.example.com
PUBLIC_HOST=http://localhost

# Change these before exposing the host to the internet.
POSTGRES_DB=chatlog
POSTGRES_USER=chatlog
POSTGRES_PASSWORD=change-me
